      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git merge --no-ff:*)",
      "Bash(git rebase:*)",
      "Bash(git worktree:*)",
      "Bash(git push origin:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(node:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh issue list:*)",
      "Bash(npx supabase migration new:*)",
      "Bash(npx supabase migration list:*)",
      "Bash(npx supabase db diff:*)",
      "Bash(npx supabase gen types:*)",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__list_tables",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__list_migrations",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__generate_typescript_types",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__get_advisors",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__get_logs",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(sudo:*)",
      "Bash(curl:* | sh)",
      "Bash(vercel --prod:*)",
      "Bash(vercel deploy --prod:*)",
      "Bash(npx supabase db reset:*)",
      "Bash(npx supabase db push:*)",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__apply_migration",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__execute_sql",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__deploy_edge_function",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__create_branch",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__delete_branch",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__merge_branch",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__reset_branch",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__rebase_branch",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__pause_project",
      "mcp__04d7f48e-805c-48d9-b8a2-7c674ed52b8d__restore_project"
    ]
  },
  "_notes": {
    "purpose": "Permission allowlist for the autonomous sprint fleet (OPS-01 §7). Lets unattended ticks do their work without prompts, while making destructive/irreversible actions impossible.",
    "push_to_main": "Pushing feature branches is allowed; the loop NEVER pushes to or merges main (procedural rule + stop condition). ENABLE GITHUB BRANCH PROTECTION on main as belt-and-suspenders so even a mistake cannot bypass review.",
    "db_writes": "Schema changes flow as migration FILES in PRs that the founder applies on merge. Autonomous DB-mutating MCP tools (apply_migration, execute_sql) are DENIED so the fleet cannot alter the live database unsupervised.",
    "secrets": "No secret-printing or deploy commands. Real secrets live only in .env.local (gitignored) / Vercel env, never committed.",
    "optional_hardening": "Consider adding a PreToolUse hook that re-blocks 'git push' targeting main and destructive patterns; omitted here to avoid environment-specific breakage. See OPS-01 §7."
  }
