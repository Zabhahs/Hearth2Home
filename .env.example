# ============================================================
# Hearth2Home — Environment Variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.
# ============================================================

# ------------------------------------------------------------
# Supabase — publishable (safe to expose to the browser)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ------------------------------------------------------------
# Supabase — server-only
# WARNING: This key bypasses Row-Level Security.
# It MUST NOT be prefixed with NEXT_PUBLIC_ and must never be
# sent to or used in client-side code.
# ------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# Database (direct connection — server-only)
# Used for raw SQL migrations and server-side queries.
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ------------------------------------------------------------
# AI — server-only
# ------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# Vendor integrations — server-only
# ------------------------------------------------------------
# SCREENING_VENDOR_API_KEY=       # FCRA-compliant CRA (e.g. SmartMove)
# ESIGN_VENDOR_API_KEY=           # E-sign ceremony provider

# ------------------------------------------------------------
# Payments — server-only
# ------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
