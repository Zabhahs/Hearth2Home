# Normalize line endings in the repo to LF (stops CRLF churn from the autonomous fleet's many commits on Windows)
* text=auto eol=lf

# Windows-native scripts keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary / generated — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
